// Prisma schema for Sidekick
// Models: User, Workout, MoodCheck

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ===== USER MODEL =====
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password             String?   // null se usar OAuth Strava
  name                 String?
  avatar               String?   // URL da foto de perfil
  planType             String    @default("free")
  stravaId             String?   @unique // ID do atleta no Strava
  stravaAccessToken    String?
  stravaRefreshToken   String?
  stravaTokenExpiresAt DateTime?
  stravaAthleteName    String?
  stravaAthleteUsername String?
  stravaAthleteProfile String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relações
  workouts      Workout[]
  moodChecks    MoodCheck[]
  profile       UserProfile?
  usageQuotas   UsageQuota[]

  @@map("users")
}

// ===== WORKOUT MODEL =====
model Workout {
  id            String    @id @default(cuid())
  userId        String
  stravaId      String?   @unique // ID da atividade no Strava
  
  // Dados básicos
  title         String
  description   String?
  date          DateTime  // Data e hora do treino
  
  // Métricas
  duration      Int       // em segundos
  distance      Float?    // em km
  pace          Float?    // velocidade média (km/h)
  avgHeartRate  Int?      // BPM médio
  maxHeartRate  Int?      // BPM máximo
  
  // Tipo e intensidade
  type          String    // "run", "cycling", "strength", etc
  intensity     String?   // "low", "moderate", "high"
  
  // Narrativa IA
  aiNarrative   String?   // Análise gerada pelo Gemini
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relação
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workouts")
  @@index([userId])
  @@index([date])
}

// ===== MOOD CHECK MODEL =====
model MoodCheck {
  id            String    @id @default(cuid())
  userId        String
  date          DateTime  @db.Date // Apenas a data, sem hora
  
  // Emoção (um por dia)
  mood          String    // "tired", "sick", "normal", "angry", "sad", "happy"
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relação
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mood_checks")
  @@unique([userId, date])  // Um humor por dia por usuário
  @@index([userId])
}

model UserProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  trainingGoal  String?
  focusArea     String?
  injuryNote    String?
  availableTime String?
  trainingMood  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UsageQuota {
  id          String   @id @default(cuid())
  userId      String
  feature     String
  used        Int      @default(0)
  limit       Int
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feature, periodStart])
  @@map("usage_quotas")
}

