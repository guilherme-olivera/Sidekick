# Backend environment example for Sidekick

# PostgreSQL connection string
# Formato recomendado:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/sidekick_db"

# Gemini AI
GEMINI_API_KEY="your-gemini-api-key-here"

# JWT authentication secret
JWT_SECRET="your-jwt-secret-here"

# Strava OAuth credentials
STRAVA_CLIENT_ID="your-strava-client-id"
STRAVA_CLIENT_SECRET="your-strava-client-secret"

# Redirect URI configured in Strava app settings
# Deve ser o mesmo valor usado em `STRAVA_REDIRECT_URI` se você mudar o padrão.
STRAVA_REDIRECT_URI="http://192.168.15.11:3000/api/strava/callback"
# Optional callback URI used by the mobile app to return from the browser.
# Default: sidekick://strava/callback
STRAVA_APP_REDIRECT_URI="sidekick://strava/callback"
STRAVA_SCOPE="activity:read_all"

# Server options
PORT=3000
NODE_ENV="development"
SERVER_URL="http://192.168.15.11:3000"
