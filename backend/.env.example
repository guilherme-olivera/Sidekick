# Backend environment example for Sidekick

# PostgreSQL connection string
# Formato recomendado:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/sidekick_db"

# Gemini AI
GEMINI_API_KEY="your-gemini-api-key-here"

# JWT authentication secret
JWT_SECRET="your-jwt-secret-here"

# Strava OAuth credentials
STRAVA_CLIENT_ID="your-strava-client-id"
STRAVA_CLIENT_SECRET="your-strava-client-secret"

# Redirect URI configured in Strava app settings
# Deve ser o mesmo valor usado em `STRAVA_REDIRECT_URI` se você mudar o padrão.
STRAVA_REDIRECT_URI="sidekick://strava/callback"

# Server options
PORT=3000
NODE_ENV="development"
